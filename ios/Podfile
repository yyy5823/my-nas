# Uncomment this line to define a global platform for your project
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # 强制所有 Pod 使用 iOS 13.0 作为最低部署目标
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'

      # 修复框架头文件引用格式问题(SDWebImage 等第三方库)
      config.build_settings['USE_HEADERMAP'] = 'NO'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
    end
  end

  # 添加脚本阶段来重新签名嵌入的 framework
  # 解决 Xcode 14+ / iOS 16+ 中 sqlite3 framework 签名验证失败问题
  main_project = installer.aggregate_targets.first.user_project
  main_target = main_project.targets.find { |t| t.name == 'Runner' }

  if main_target
    # 检查是否已存在签名脚本
    existing_script = main_target.shell_script_build_phases.find { |p| p.name == 'Codesign Embedded Frameworks' }

    unless existing_script
      phase = main_target.new_shell_script_build_phase('Codesign Embedded Frameworks')
      phase.shell_script = <<-SCRIPT
#!/bin/bash
# 重新签名所有嵌入的 framework（解决预编译 framework 签名问题）
FRAMEWORKS_DIR="${BUILT_PRODUCTS_DIR}/${FRAMEWORKS_FOLDER_PATH}"
if [ -d "$FRAMEWORKS_DIR" ]; then
  find "$FRAMEWORKS_DIR" -name '*.framework' -type d | while read FRAMEWORK; do
    echo "Signing: $FRAMEWORK"
    /usr/bin/codesign --force --sign "${EXPANDED_CODE_SIGN_IDENTITY}" --preserve-metadata=identifier,entitlements --timestamp=none "$FRAMEWORK" || true
  done
fi
      SCRIPT
      phase.show_env_vars_in_log = '0'

      # 将脚本移动到 Embed Frameworks 之后
      embed_phase = main_target.build_phases.find { |p| p.display_name == 'Embed Frameworks' }
      if embed_phase
        embed_index = main_target.build_phases.index(embed_phase)
        main_target.build_phases.move(phase, embed_index + 1)
      end

      main_project.save
    end
  end
end
